{
    "semi": true,
    "singleQuote": false,
    "printWidth": 100,
    "trailingComma": "all",
    "tabWidth": 2,
    "overrides": [
      {
        "files": "*.sol",
        "options": {
          "pluginSearchDirs": false,
          "plugins": ["prettier-plugin-solidity"],
          "singleQuote": false,
          "bracketSpacing": true
        }
      }
    ]
  }
  