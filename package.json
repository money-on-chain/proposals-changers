{
  "devDependencies": {
    "@commitlint/cli": "17.6.3",
    "@commitlint/config-conventional": "17.6.3",
    "@nomicfoundation/hardhat-ethers": "4.0.0",
    "@nomicfoundation/hardhat-network-helpers": "3.0.0",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "3.0.0",
    "@nomicfoundation/hardhat-verify": "3.0.0",
    "@openzeppelin/contracts": "5.4.0",
    "@openzeppelin/contracts-upgradeable": "5.4.0",
    "@typescript-eslint/eslint-plugin": "5.59.7",
    "@typescript-eslint/parser": "5.59.7",
    "dotenv": "17.2.1",
    "eslint": "8.41.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-no-only-tests": "3.1.0",
    "eslint-plugin-prettier": "5.2.5",
    "ethers": "6.15.0",
    "forge-std": "github:foundry-rs/forge-std",
    "hardhat": "3.0.1",
    "husky": "8.0.3",
    "prettier": "3.5.3",
    "prettier-plugin-solidity": "1.4.2",
    "solhint": "6.0.1",
    "solhint-plugin-prettier": "0.1.0",
    "@nomicfoundation/hardhat-ignition": "^3.0.0",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.18.0",
    "chai": "5.3.3",
    "mocha": "^11.7.1",
    "typescript": "5.7.3"
  },
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "lint": "npm run lint:sol && npm run lint:ts && npm run prettier:check",
    "lint:sol": "solhint --config .solhint.json --max-warnings 0 \"contracts/**/*.sol\"",
    "lint:ts": "eslint --config ./.eslintrc.yaml --ignore-path ./.eslintignore \"**/*.{js,ts}\"",
    "lint-fix": "eslint --fix --config ./.eslintrc.yaml --ignore-path ./.eslintignore \"**/*.{js,ts}\"",
    "prettier": "prettier --config .prettierrc --write \"**/*.{js,json,md,sol,ts,yml}\"",
    "prettier:check": "prettier --config .prettierrc --check \"**/*.{js,json,md,sol,ts,yml}\"",
    "deploy:alpha-testnet:remove-panic-button": "npx hardhat run scripts/remove_panic_button/deploy.js --network rskAlphaTestnet",
    "deploy:testnet:remove-panic-button": "npx hardhat run scripts/remove_panic_button/deploy.js --network rskTestnet",
    "deploy:mainnet:remove-panic-button": "npx hardhat run scripts/remove_panic_button/deploy.js --network rskMainnet",
    "validate:prevote:alpha-testnet:remove-panic-button": "npx hardhat run scripts/remove_panic_button/validate_prevote.js --network rskAlphaTestnet",
    "validate:prevote:testnet:remove-panic-button": "npx hardhat run scripts/remove_panic_button/validate_prevote.js --network rskTestnet",
    "validate:prevote:mainnet:remove-panic-button": "npx hardhat run scripts/remove_panic_button/validate_prevote.js --network rskMainnet",
    "verify:alpha-testnet:remove-panic-button": "npx hardhat run scripts/remove_panic_button/verify.js --network rskAlphaTestnet",
    "verify:testnet:remove-panic-button": "npx hardhat run scripts/remove_panic_button/verify.js --network rskTestnet",
    "verify:mainnet:remove-panic-button": "npx hardhat run scripts/remove_panic_button/verify.js --network rskMainnet",
    "test:fork:alpha-testnet:remove-panic-button": "FORK_URL=$RPC_URL_RSK_TESTNET FORK_BLOCK=$FORK_BLOCK FORK_NETWORK_NAME=rskAlphaTestnet hardhat test test/fork/remove_panic_button.fork.spec.js",
    "test:fork:mainnet:remove-panic-button": "FORK_URL=$RPC_URL_RSK_MAINNET FORK_BLOCK=$FORK_BLOCK FORK_NETWORK_NAME=rskMainnet hardhat test test/fork/remove_panic_button.fork.spec.js",
    "deploy:alpha-testnet:fees-and-bitprorate": "npx hardhat run scripts/fees_and_bitprorate/deploy.js --network rskAlphaTestnet",
    "deploy:testnet:fees-and-bitprorate": "npx hardhat run scripts/fees_and_bitprorate/deploy.js --network rskTestnet",
    "deploy:mainnet:fees-and-bitprorate": "npx hardhat run scripts/fees_and_bitprorate/deploy.js --network rskMainnet",
    "validate:prevote:alpha-testnet:fees-and-bitprorate": "npx hardhat run scripts/fees_and_bitprorate/validate_prevote.js --network rskAlphaTestnet",
    "validate:prevote:testnet:fees-and-bitprorate": "npx hardhat run scripts/fees_and_bitprorate/validate_prevote.js --network rskTestnet",
    "validate:prevote:mainnet:fees-and-bitprorate": "npx hardhat run scripts/fees_and_bitprorate/validate_prevote.js --network rskMainnet",
    "verify:alpha-testnet:fees-and-bitprorate": "npx hardhat run scripts/fees_and_bitprorate/verify.js --network rskAlphaTestnet",
    "verify:testnet:fees-and-bitprorate": "npx hardhat run scripts/fees_and_bitprorate/verify.js --network rskTestnet",
    "verify:mainnet:fees-and-bitprorate": "npx hardhat run scripts/fees_and_bitprorate/verify.js --network rskMainnet",
    "test:fees-and-bitprorate": "npx hardhat test test/fees_and_bitprorate.spec.js",
    "test:fork:alpha-testnet:fees-and-bitprorate": "FORK_URL=$RPC_URL_RSK_TESTNET FORK_BLOCK=$FORK_BLOCK FORK_NETWORK_NAME=rskAlphaTestnet hardhat test test/fork/fees_and_bitprorate.fork.spec.js",
    "test:fork:mainnet:fees-and-bitprorate": "FORK_URL=$RPC_URL_RSK_MAINNET FORK_BLOCK=$FORK_BLOCK FORK_NETWORK_NAME=rskMainnet hardhat test test/fork/fees_and_bitprorate.fork.spec.js"
  },
  "type": "module"
}
