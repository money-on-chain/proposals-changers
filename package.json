{
  "devDependencies": {
    "@moc/oracles": "git+ssh://git@github.com/money-on-chain/OMoC-Decentralized-Oracle.git#v3.0.5",
    "@moc/rbtc": "git+ssh://git@github.com/money-on-chain/main-RBTC-contract.git#v3.0.5",
    "@moc/roc": "git+ssh://git@github.com/money-on-chain/roc-sc-protocol-v2.git#v3.0.5",
    "@openzeppelin/contracts-ethereum-package": "3.0.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.0",
    "@openzeppelin/contracts": "4.9.0",
    "@openzeppelin/contracts-upgradeable": "4.9.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "chai": "^5.3.1",
    "dotenv": "^17.2.1",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.21.3",
    "ethers": "^6.15.0",
    "forge-std": "github:foundry-rs/forge-std",
    "globals": "^16.3.0",
    "hardhat": "^3.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "2.8.8",
    "prettier-plugin-solidity": "^1.4.3",
    "solhint": "^6.0.1",
    "typescript-eslint": "^8.41.0"
  },
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "lint": "eslint 'scripts/**/*.{ts,js,cjs,mjs}' 'tasks/**/*.{ts,js,cjs,mjs}' 'test/**/*.{ts,js,cjs,mjs}' 'hardhat.config.{ts,js}' && solhint 'contracts/**/*.sol'",
    "lint:fix": "eslint 'scripts/**/*.{ts,js,cjs,mjs}' 'tasks/**/*.{ts,js,cjs,mjs}' 'test/**/*.{ts,js,cjs,mjs}' 'hardhat.config.{ts,js}' --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "fix:all": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix && prettier . --write",
    "check:all": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs && prettier . --check",
    "deploy:alpha-testnet:coin-pair-price-upgrade:ignition": "npx hardhat ignition deploy ignition/modules/CoinPairPriceUpgradeChanger.js --network rskAlphaTestnet",
    "deploy:testnet:coin-pair-price-upgrade:ignition": "npx hardhat ignition deploy ignition/modules/CoinPairPriceUpgradeChanger.js --network rskTestnet",
    "deploy:mainnet:coin-pair-price-upgrade:ignition": "npx hardhat ignition deploy ignition/modules/CoinPairPriceUpgradeChanger.js --network rskMainnet",
    "count:set-oracle-address": "node scripts/oracles/count_set_oracle_address.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "contracts/**/*.sol": [
      "prettier --write",
      "solhint --max-warnings=0"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {},
  "type": "module"
}
